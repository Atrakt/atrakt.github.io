# ==============================================================================
# 1. AUTHENTICATION (Private - Build time only)
# ==============================================================================
# Required to fetch repositories data via GraphQL API
GH_PAT=ghp_your_secret_token_here

# ==============================================================================
# 2. SITE METADATA & META TAGS (Public - Used in <head>)
# ==============================================================================
VITE_APP_TITLE="Full Name | Portfolio"
VITE_APP_DESCRIPTION="Showcase of open-source projects and technical experiments."
VITE_APP_KEYWORDS="Software, Open-Source, Engineering"
VITE_APP_URL="https://username.github.io/"
# Optional: Absolute URL to an image for social media previews (OpenGraph)
VITE_APP_LOGO_URL="" 

# ==============================================================================
# 3. JSON-LD / SCHEMA.ORG (Public - Structured Data for SEO)
# ==============================================================================
VITE_APP_NAME="Full Name"
VITE_APP_JOB_TITLE="Software Engineer"
VITE_APP_JSONLD_DESC="Developer focused on building clean and efficient digital experiences."
VITE_APP_GH_URL="https://github.com/username"

# ==============================================================================
# 4. UI & CONSTANTS (Public - Used in Footer/About)
# ==============================================================================
VITE_APP_GH_USERNAME="username"
VITE_APP_SINCE="2024"
